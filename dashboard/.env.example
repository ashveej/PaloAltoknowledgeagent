# Copy to .env and fill in. Without a key the app runs in MOCK mode
# (deterministic canned LLM output) so you can demo the full pipeline offline.
ANTHROPIC_API_KEY=

# Models
CLASSIFY_MODEL=claude-haiku-4-5
FACTS_MODEL=claude-opus-4-8
STYLE_MODEL=claude-opus-4-8

# Embeddings + reranker (local, no key needed)
EMBED_MODEL=all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Answer style
MAX_ANSWER_WORDS=180

# SME email notifications. Leave SMTP_HOST blank to run in offline "outbox" mode
# (emails are written to data/outbox/*.eml). Set these to send for real.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=knowledge-agent@paloaltonetworks-demo.com
# Send ALL SME notifications to one address instead of the per-group lists (testing):
SME_NOTIFY_TO=
APP_BASE_URL=http://localhost:8077
